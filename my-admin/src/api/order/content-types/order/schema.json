{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "order_id": {
      "type": "string"
    },
    "items": {
      "type": "json"
    },
    "total_amount": {
      "type": "decimal"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "en_attente",
        "valide",
        "rejete",
        "payé",
        "livré"
      ]
    },
    "client": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "delivery_info": {
      "type": "component",
      "repeatable": false,
      "component": "order.delivery-info"
    },
    "admin_notes": {
      "type": "text"
    }
  }
}
